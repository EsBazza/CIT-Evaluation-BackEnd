SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>/<neon-db>?sslmode=require&stringtype=unspecified
SPRING_DATASOURCE_USERNAME=<neon-username>
SPRING_DATASOURCE_PASSWORD=<neon-password>
GOOGLE_CLIENT_ID=<google-oauth-client-id>
APP_ADMIN_USERNAME=<admin-username>
APP_ADMIN_PASSWORD=<admin-password>
APP_CORS_ALLOWED_ORIGINS=https://<your-vercel-app>.vercel.app,https://*.vercel.app,http://localhost:5173

# Recommended on Render free instances (filesystem can be ephemeral)
APP_KEYS_PRIVATE_BASE64=<base64-pkcs8-private-key>
APP_KEYS_PUBLIC_BASE64=<base64-x509-public-key>